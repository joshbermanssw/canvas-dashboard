# Canvas API Configuration
# Copy this file to .env.local and fill in your values

# Your Canvas API token
# Get it from: Canvas → Account → Settings → Approved Integrations → New Access Token
CANVAS_API_TOKEN=your_token_here
NEXT_PUBLIC_CANVAS_API_TOKEN=your_token_here

# Your Canvas instance URL (no trailing slash)
# Example: https://canvas.university.edu
CANVAS_BASE_URL=https://canvas.your-school.edu
NEXT_PUBLIC_CANVAS_BASE_URL=https://canvas.your-school.edu
